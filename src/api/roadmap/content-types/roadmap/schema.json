{
  "kind": "collectionType",
  "collectionName": "roadmaps",
  "info": {
    "singularName": "roadmap",
    "pluralName": "roadmaps",
    "displayName": "Roadmap Milestone",
    "description": "Product roadmap milestones (upcoming and previous releases)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Release title (e.g., Release 1.3: Dolores)"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the milestone"
    },
    "releaseDate": {
      "type": "date",
      "required": true,
      "description": "Release month (pick 1st of month, e.g. 2025-03-01 for March 2025)"
    },
    "githubUrl": {
      "type": "string",
      "required": false,
      "description": "Optional URL to GitHub release or milestone"
    }
  }
}
